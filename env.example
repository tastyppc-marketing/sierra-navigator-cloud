# Sierra Navigator Cloud — example environment.
# Copy to `.env` for local dev (gitignored), or inject these as container env in prod.

# --- Sierra admin login (operator tenant) ---------------------------------
SIERRA_SITE=
SIERRA_USERNAME=
SIERRA_PASSWORD=

# --- WorkOS AuthKit (OAuth resource server) -------------------------------
# Set AUTHKIT_DOMAIN to enable OAuth. Without it the server FAILS CLOSED unless
# SIERRA_MCP_ALLOW_NO_AUTH is set AND the bind host is loopback (see below).
AUTHKIT_DOMAIN=                                  # e.g. https://<env>.authkit.app
MCP_PUBLIC_BASE_URL=https://sierra.tastyautomations.com   # this server's public URL (token audience)
WORKOS_CLIENT_ID=                                # reserved (not read at runtime yet)
# Only these token subjects (email or sub, comma-separated) may use the server.
# Empty = allow any authenticated subject. SET THIS in production.
SIERRA_MCP_SUBJECT_ALLOWLIST=

# --- Local dev escape hatch (loopback only) -------------------------------
# Run UNAUTHENTICATED when AUTHKIT_DOMAIN is unset — honored ONLY when the bind host
# is loopback. The Docker container binds 0.0.0.0, so this is REFUSED there (by
# design, #13). DEV ONLY — never in production.
SIERRA_MCP_ALLOW_NO_AUTH=
SIERRA_MCP_BIND_HOST=                             # set 127.0.0.1 for a local no-auth uvicorn run

# --- Stores / guardrails (optional; sensible defaults) --------------------
# Audit/ledger SQLite path. In Docker this is set to the persistent volume by
# docker-compose.yml; locally it defaults to ./data/sierra_mcp.db.
SIERRA_MCP_DB_PATH=
# Volume caps (defaults: delete-per-call 10, write-session 50, delete-session 20).
SIERRA_MCP_DELETE_CALL_CAP=
SIERRA_MCP_WRITE_SESSION_CAP=
SIERRA_MCP_DELETE_SESSION_CAP=
